# ─────────────────────────────────────────────────────────
#  SHODAN XPLOITER v1.0 — .env.example
#  Copy to .env and fill in your real values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── AI — Anthropic Claude (only provider) ────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Delay in seconds between Phase 2 and Phase 3 (default: 2)
CLAUDE_PHASE_DELAY=0

# ── Collectors ───────────────────────────────────────────

# Shodan API key (optional — falls back to passive web scraper if not set)
# Get yours at: https://account.shodan.io
SHODAN_API_KEY=

# IPInfo token (optional — uses free tier (50k req/mo) if not set)
# Get yours at: https://ipinfo.io/account/token
IPINFO_TOKEN=

# ── Output ───────────────────────────────────────────────
# Directory where reports are saved (default: .reports)
OUTPUT_DIR=.reports
